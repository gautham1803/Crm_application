# ============================================================
# Acufy CRM — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ---------- App ----------
APP_ENV=development
DEV_AUTH_BYPASS=true
# Set to false in production; enables dev login card

# ---------- Auth0 (skip for now — dev bypass is on) ----------
# Sign up: https://auth0.com (free tier: 7,500 MAU)
# Create a Regular Web Application + API
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.acufy.local
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret

# ---------- Database ----------
DATABASE_URL=postgresql+psycopg://acufy:acufy_secret@postgres:5432/acufy
# For running outside Docker:
# DATABASE_URL=postgresql+psycopg://acufy:acufy_secret@localhost:5432/acufy

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0
# For running outside Docker:
# REDIS_URL=redis://localhost:6379/0

# ---------- LLM (Free Tier) ----------
# Groq: https://console.groq.com → free API key
GROQ_API_KEY=gsk_your_groq_api_key
# Google AI Studio: https://aistudio.google.com → free API key
GOOGLE_API_KEY=your_google_api_key
LLM_DEFAULT_MODEL=groq/llama-3.3-70b-versatile
LLM_FAST_MODEL=groq/llama-3.1-8b-instant
LLM_FALLBACK_MODEL=gemini/gemini-1.5-flash
LLM_BUDGET_PER_TEAM_DAILY_USD=5.0
LLM_BUDGET_PER_USER_DAILY_USD=1.0

# ---------- SendGrid (Email) ----------
# Sign up: https://sendgrid.com (free tier: 100 emails/day)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@acufy.local

# ---------- Twilio (SMS) ----------
# Sign up: https://twilio.com (free trial credits included)
TWILIO_ACCOUNT_SID=ACyour_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_MESSAGING_SERVICE_SID=MGyour_messaging_service_sid

# ---------- Supabase (Storage) ----------
# Sign up: https://supabase.com (free tier: 500MB storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_STORAGE_BUCKET=acufy-documents

# ---------- Langfuse (LLM Observability) ----------
# Self-hosted via Docker Compose — no signup needed
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_HOST=http://langfuse-web:3000

# ---------- Langfuse Internal DB ----------
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse_secret@langfuse-postgres:5432/langfuse
LANGFUSE_NEXTAUTH_SECRET=my-langfuse-secret
LANGFUSE_NEXTAUTH_URL=http://localhost:3100
LANGFUSE_SALT=my-langfuse-salt

# ---------- Compliance ----------
COMPLIANCE_RULE_PACKS=["universal"]
